[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/ui/time_controls.gd" id="1_tc"]

[node name="TimeControls" type="HBoxContainer"]
script = ExtResource("1_tc")

[node name="PauseBtn" type="Button" parent="."]
custom_minimum_size = Vector2(40, 30)
text = "||"
tooltip_text = "Pause"

[node name="HalveBtn" type="Button" parent="."]
custom_minimum_size = Vector2(40, 30)
text = "<<"
tooltip_text = "Halve Speed"

[node name="SpeedLabel" type="Label" parent="."]
custom_minimum_size = Vector2(50, 0)
horizontal_alignment = 1
vertical_alignment = 1
text = "1x"

[node name="DobrarBtn" type="Button" parent="."]
custom_minimum_size = Vector2(80, 30)
text = "DOBRAR >>"
tooltip_text = "Double Speed"
