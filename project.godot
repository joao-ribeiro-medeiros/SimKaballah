; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited with a text editor if you know what you're doing.

config_version=5

[application]

config/name="SimKaballah"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.4")

[autoload]

SignalBus="*res://autoloads/signal_bus.gd"
GameClock="*res://autoloads/game_clock.gd"
CosmicBalance="*res://autoloads/cosmic_balance.gd"
EncounterManager="*res://autoloads/encounter_manager.gd"
PartyManager="*res://autoloads/party_manager.gd"
Chronicle="*res://autoloads/chronicle.gd"
SaveManager="*res://autoloads/save_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
